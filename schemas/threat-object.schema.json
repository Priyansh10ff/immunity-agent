{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Prismor Agent Immunity Feed Schema",
    "type": "object",
    "required": [
        "version",
        "updated",
        "description",
        "advisories"
    ],
    "properties": {
        "version": {
            "type": "string",
            "description": "Schema version"
        },
        "updated": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp of the last intelligence update"
        },
        "description": {
            "type": "string",
            "description": "A brief description of the intelligence package"
        },
        "advisories": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "id",
                    "severity",
                    "type",
                    "title",
                    "description",
                    "affected",
                    "action",
                    "published",
                    "references"
                ],
                "properties": {
                    "id": {
                        "type": "string",
                        "description": "Unique identifier (e.g., CVE-XXXX-YYYY or PRISMOR-2026-0001)"
                    },
                    "severity": {
                        "type": "string",
                        "enum": [
                            "critical",
                            "high",
                            "medium",
                            "low",
                            "unknown"
                        ],
                        "description": "Evaluated risk level"
                    },
                    "type": {
                        "type": "string",
                        "description": "The specific AI threat vector",
                        "enum": [
                            "prompt_injection",
                            "data_exfiltration",
                            "unsafe_tool_execution",
                            "jailbreak",
                            "policy_bypass",
                            "dependency_vulnerability",
                            "model_denial_of_service",
                            "unknown"
                        ]
                    },
                    "title": {
                        "type": "string",
                        "description": "Brief summary of the threat"
                    },
                    "description": {
                        "type": "string",
                        "description": "Detailed explanation of the attack vector"
                    },
                    "affected": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "description": "CPE-style strings defining vulnerable frameworks"
                    },
                    "action": {
                        "type": "string",
                        "description": "The prescribed immune response"
                    },
                    "published": {
                        "type": "string",
                        "format": "date-time",
                        "description": "ISO 8601 timestamp of publication"
                    },
                    "references": {
                        "type": "array",
                        "items": {
                            "type": "string",
                            "format": "uri"
                        },
                        "description": "URLs to original CVEs, PoCs, or write-ups"
                    }
                },
                "additionalProperties": false
            }
        }
    },
    "additionalProperties": false
}